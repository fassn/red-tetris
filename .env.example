# Socket URL — leave empty for same-origin (custom server serves both)
# Set explicitly only if Socket.IO runs on a different server
NEXT_PUBLIC_SOCKET_URL=

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Data directory for SQLite (default: ./data)
DATA_DIR=./data

# Socket.IO CORS (optional — for split frontend/backend deployments)
# SOCKET_CORS_ORIGIN=https://example.com

# Log level for server logger (debug | info | warn | error)
# LOG_LEVEL=info